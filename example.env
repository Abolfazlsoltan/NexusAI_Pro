# ───────────────────────────────────────────────────────────────
# .env.example — متغیرهای محیطی برای NexusAI v6
# ───────────────────────────────────────────────────────────────
#
# این فایل نمونه است و نشان می‌دهد که کدام متغیرهای محیطی
# برای اجرای برنامه لازم است.
#
# 📋 دستورالعمل:
# 1. این فایل را کپی کنید: cp .env.example .env
# 2. فایل .env را باز کنید و مقادیر واقعی خود را وارد کنید
# 3. فایل .env را در .gitignore قرار دهید (قبلاً انجام شده است)
# 4. هرگز فایل .env واقعی را commit نکنید!
#
# ───────────────────────────────────────────────────────────────

# ── HuggingFace API Token ──────────────────────────────────────
# دریافت از: https://huggingface.co/settings/tokens
# این توکن برای استفاده از Hugging Face Inference API لازم است
HF_TOKEN=your_hugging_face_token_here

# ── Groq API Key (اختیاری) ────────────────────────────────────
# دریافت از: https://console.groq.com/keys
# این کلید برای استفاده از Groq API لازم است (در صورت استفاده)
GROQ_API_KEY=your_groq_api_key_here

# ── OpenAI API Key (اختیاری) ──────────────────────────────────
# دریافت از: https://platform.openai.com/api-keys
# این کلید برای استفاده از OpenAI API لازم است (در صورت استفاده)
OPENAI_API_KEY=your_openai_api_key_here

# ───────────────────────────────────────────────────────────────
# نکات مهم:
# ───────────────────────────────────────────────────────────────
#
# ✅ نیاز‌مند:
#    - HF_TOKEN: برای استفاده از مدل‌های Hugging Face اجباری است
#
# ❓ اختیاری:
#    - GROQ_API_KEY و OPENAI_API_KEY تنها در صورتی لازم هستند
#      که می‌خواهید از این providers استفاده کنید
#
# 🔐 امنیت:
#    - هرگز کلیدهای واقعی را در version control وارد نکنید
#    - فایل .env محلی باقی می‌ماند و commit نمی‌شود
#    - برای اشتراک‌گذاری، فقط این فایل (.env.example) را ارسال کنید
#
# 📝 دریافت توکن‌ها:
#    1. برای HuggingFace:
#       - به https://huggingface.co/settings/tokens رفته
#       - یک Token جدید ایجاد کنید
#       - آن را در اینجا قرار دهید
#
#    2. برای Groq:
#       - به https://console.groq.com/keys رفته
#       - یک API Key جدید ایجاد کنید
#       - آن را در اینجا قرار دهید
#
#    3. برای OpenAI:
#       - به https://platform.openai.com/api-keys رفته
#       - یک API Key جدید ایجاد کنید
#       - آن را در اینجا قرار دهید
#
# ───────────────────────────────────────────────────────────────
