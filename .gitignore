# ───────────────────────────────────────────────────────────────
# .gitignore — NexusAI v6
# ───────────────────────────────────────────────────────────────

# ── متغیرهای محیطی و تنظیمات حساس ────────────────────────────
.env
.env.local
.env.*.local
.env.production.local

# ── دایرکتوری‌های حذف شده توسط Python ──────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# ── محیط‌های مجازی ──────────────────────────────────────────
venv/
ENV/
env/
.venv

# ── IDE و ویرایشگرهای متن ───────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ── لاگ‌ها و فایل‌های موقتی ────────────────────────────────
*.log
*.pot
*.mo
.coverage
htmlcov/
.pytest_cache/
.tox/
.hypothesis/
*.tmp
*.bak

# ── فایل‌های سیستم ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── فایل‌های پروژه‌ی NexusAI ───────────────────────────────
config.json
history.json
.NexusAI/

# ── فایل‌های دیتابیس ──────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── فایل‌های دیسک موقتی ───────────────────────────────────
*.tmp
*.temp
*.cache

# ── فایل‌های پروژه‌ی Kivy (اگر استفاده شود) ─────────────
*.kv.bak

# ── دایرکتوری‌های قفل و موقتی ──────────────────────────────
.lock
.locked
